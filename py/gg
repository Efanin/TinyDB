async def getmes(tag):
    url = "http://tinywebdb.appinventor.mit.edu/getvalue"
    set = new URLSearchParams()
    set.append("tag", tag)

    set.append("fmt", "html")
    resp = await fetch(url,{method: "POST", body: set.toString()})
    text = await resp.text()
    match = text.match(/\["VALUE","[^"]*","([^"]*)"\]/)
    mes = match[1]
    return mes 

async def send(tag, text):
    url = "http://tinywebdb.appinventor.mit.edu/storeavalue"
    set = new URLSearchParams()
    set.append("tag", tag)
    set.append("value", text)
    set.append("fmt", "html")
    resp = await fetch(url,{method: "POST", body: set.toString()})
    return resp
    
async def main():
    name = input("ваше имя")
    friend = input("имя друга")
    chat = ""
    if name > friend:
        chat = name + friend
    else:
        chat = friend + name
    while true:
        text = await getmes(chat)
        mes = input("сообщение")
        if mes != "":
            mes = name + ": " + mes
            send(chat,text + "</br>" + mes)
        print(text)
        print(mes)
main()
